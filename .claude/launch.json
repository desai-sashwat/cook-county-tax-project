{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "JupyterLab",
      "runtimeExecutable": ".venv/bin/jupyter",
      "runtimeArgs": ["lab", "--notebook-dir=.", "--no-browser"],
      "port": 8888
    },
    {
      "name": "Jupyter Notebook",
      "runtimeExecutable": ".venv/bin/jupyter",
      "runtimeArgs": ["notebook", "--notebook-dir=.", "--no-browser"],
      "port": 8888
    }
  ]
}
